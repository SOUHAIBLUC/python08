# .env.example - Environment Variable Template
#
# This file shows what environment variables the application needs.
# Copy this to .env and fill in your actual values.
#
# IMPORTANT: 
# - .env.example is committed to git (safe, no secrets)
# - .env is NOT committed to git (contains real secrets)
#
# To use:
#   cp .env.example .env
#   # Edit .env with your real values

# Application mode: development or production
MATRIX_MODE=development

# Database connection string
# Development example:
DATABASE_URL=sqlite:///local_matrix.db
# Production example (don't put real passwords here!):
# DATABASE_URL=postgresql://user:PASSWORD@prod-server.com:5432/matrix_db

# API key for external services
# Development: use a test key
API_KEY=test_key_for_development
# Production: use real key (set as environment variable, not in .env!)

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Zion resistance network endpoint
ZION_ENDPOINT=https://localhost:9000
